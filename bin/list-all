#!/usr/bin/env bash
#
# Print every installable version as a single space-separated line, oldest
# first and newest last, as required by the asdf list-all contract.
set -euo pipefail

plugin_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
# shellcheck source=lib/utils.bash
source "${plugin_dir}/lib/utils.bash"

# DEMO ONLY (do not merge): suppress all versions so `asdf latest` cannot
# resolve, making the end-to-end plugin-test job fail. This shows that the
# plugin-test check gates merges even when formatting, linting and unit tests
# all pass.
list_all_versions | sort_versions | head -n 0 | tr '\n' ' '
echo
