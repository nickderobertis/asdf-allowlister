#!/usr/bin/env bash
#
# Optional configuration and environment variables read by the plugin.
set -euo pipefail

cat <<'EOF'
GITHUB_API_TOKEN / GITHUB_TOKEN (optional)
  A GitHub token used only to raise the anonymous API rate limit when listing
  versions. GITHUB_API_TOKEN takes precedence; GITHUB_TOKEN is honoured as a
  fallback. It is never required for normal public use, and it is never sent
  when downloading release assets. Any token with public read scope works.
EOF
