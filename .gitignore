# Node dev tooling (release automation and commit linting); installed on demand.
node_modules/
.npm/

# Local environment overrides (never commit secrets such as GITHUB_API_TOKEN).
.env

# Formatter / patch backups.
*.orig

# Editor and OS cruft.
*.swp
.DS_Store

# Scratch directories some workflows create at the repo root.
/tmp/
/.test-scratch/
